generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== UTILISATEUR =====
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  name              String
  avatar            String?
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  isSuspended       Boolean   @default(false)
  isEmailVerified   Boolean   @default(false)
  country           String?   @default("HT")
  deviceToken       String?
  currentDeviceId   String?
  installDate       DateTime?
  uninstallDate     DateTime?
  trialEndsAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  subscription      Subscription?
  payments          Payment[]
  favorites         Favorite[]
  watchHistory      WatchHistory[]
  watchProgress     WatchProgress[]
  movieRequests     MovieRequest[]
  likes             Like[]
  sessions          UserSession[]

  @@map("users")
}

// ===== RÔLES =====
enum Role {
  USER
  ADMIN
}

// ===== SESSION UTILISATEUR =====
model UserSession {
  id          String   @id @default(uuid())
  deviceId    String
  deviceName  String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("user_sessions")
}

// ===== CATÉGORIE =====
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  movies      Movie[]
  series      Serie[]

  @@map("categories")
}

// ===== FILM =====
model Movie {
  id            String   @id @default(uuid())
  title         String
  description   String?
  thumbnail     String?
  banner        String?
  videoUrl      String?
  trailerUrl    String?
  duration      Int?
  releaseYear   Int?
  rating        Float?   @default(0)
  views         Int      @default(0)
  likes         Int      @default(0)
  isPublished   Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  favorites     Favorite[]
  watchHistory  WatchHistory[]
  watchProgress WatchProgress[]
  subtitles     Subtitle[]
  userLikes     Like[]
  analytics     MovieAnalytic[]
  movieRequests MovieRequest[]

  @@map("movies")
}

// ===== SÉRIE =====
model Serie {
  id            String    @id @default(uuid())
  title         String
  description   String?
  thumbnail     String?
  banner        String?
  isPublished   Boolean   @default(false)
  isHidden      Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  releaseYear   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  seasons       Season[]

  @@map("series")
}

// ===== SAISON =====
model Season {
  id          String    @id @default(uuid())
  number      Int
  title       String?
  createdAt   DateTime  @default(now())

  // Relations
  serieId     String
  serie       Serie     @relation(fields: [serieId], references: [id], onDelete: Cascade)
  episodes    Episode[]

  @@map("seasons")
}

// ===== ÉPISODE =====
model Episode {
  id          String    @id @default(uuid())
  number      Int
  title       String
  description String?
  videoUrl    String?
  thumbnail   String?
  duration    Int?
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  seasonId    String
  season      Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("episodes")
}

// ===== ANALYTIQUE FILM =====
model MovieAnalytic {
  id              String   @id @default(uuid())
  watchedSeconds  Int      @default(0)
  totalSeconds    Int      @default(0)
  completed       Boolean  @default(false)
  watchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  movieId         String
  movie           Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId          String

  @@unique([userId, movieId])
  @@map("movie_analytics")
}

// ===== LIKE =====
model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("likes")
}

// ===== SOUS-TITRES =====
model Subtitle {
  id        String   @id @default(uuid())
  language  String
  fileUrl   String
  createdAt DateTime @default(now())

  // Relations
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("subtitles")
}

// ===== ABONNEMENT =====
model Subscription {
  id          String             @id @default(uuid())
  status      SubscriptionStatus @default(INACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ===== STATUT ABONNEMENT =====
enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  PENDING
  TRIAL
}

// ===== PAIEMENT =====
model Payment {
  id              String        @id @default(uuid())
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  screenshot      String?
  transactionRef  String?
  notes           String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ===== MÉTHODE DE PAIEMENT =====
enum PaymentMethod {
  MONCASH
  NATCASH
  BANK_TRANSFER
}

// ===== STATUT PAIEMENT =====
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ===== INFORMATIONS DE PAIEMENT =====
model PaymentInfo {
  id            String   @id @default(uuid())
  method        String   @unique
  number        String
  holderName    String
  bankName      String?
  instructions  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payment_info")
}

// ===== FAVORIS =====
model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("favorites")
}

// ===== HISTORIQUE =====
model WatchHistory {
  id        String   @id @default(uuid())
  watchedAt DateTime @default(now())

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("watch_history")
}

// ===== PROGRESSION DE LECTURE =====
model WatchProgress {
  id          String   @id @default(uuid())
  progress    Int      @default(0)
  duration    Int      @default(0)
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId     String
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("watch_progress")
}

// ===== BANNIÈRE =====
model Banner {
  id          String   @id @default(uuid())
  title       String
  image       String
  link        String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

// ===== ANNONCE =====
model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  image       String?
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}

// ===== DEMANDE DE FILM =====
model MovieRequest {
  id          String              @id @default(uuid())
  title       String
  description String?
  status      MovieRequestStatus  @default(PENDING)
  createdAt   DateTime            @default(now())

  // Relations
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId     String?
  movie       Movie?              @relation(fields: [movieId], references: [id])

  @@map("movie_requests")
}

// ===== STATUT DEMANDE =====
enum MovieRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ===== MESSAGE ADMIN =====
model AdminMessage {
  id          String   @id @default(uuid())
  title       String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("admin_messages")
}

// ===== VÉRIFICATION EMAIL =====
model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verifications")
}

// ===== MOT DE PASSE OUBLIÉ =====
model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_resets")
}